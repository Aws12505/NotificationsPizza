{
    "openapi": "3.0.3",
    "info": {
        "title": "Notifications & Announcements API",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "https://api.your-domain.com"
        }
    ],
    "paths": {
        "/api/announcements": {
            "get": {
                "summary": "Get all announcements (admin)",
                "tags": ["Announcements"],
                "security": [{ "bearerAuth": [] }],
                "responses": {
                    "200": {
                        "description": "Paginated announcements"
                    }
                }
            },
            "post": {
                "summary": "Create announcement",
                "tags": ["Announcements"],
                "security": [{ "bearerAuth": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/AnnouncementCreate"
                            }
                        }
                    }
                },
                "responses": {
                    "201": { "description": "Created" }
                }
            }
        },

        "/api/announcements/{id}": {
            "get": {
                "summary": "Get single announcement",
                "tags": ["Announcements"],
                "security": [{ "bearerAuth": [] }],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "integer" }
                    }
                ],
                "responses": {
                    "200": { "description": "OK" }
                }
            },
            "put": {
                "summary": "Update announcement",
                "tags": ["Announcements"],
                "security": [{ "bearerAuth": [] }],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "integer" }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/AnnouncementUpdate"
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Updated" }
                }
            },
            "delete": {
                "summary": "Delete announcement",
                "tags": ["Announcements"],
                "security": [{ "bearerAuth": [] }],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "integer" }
                    }
                ],
                "responses": {
                    "200": { "description": "Deleted" }
                }
            }
        },

        "/api/announcements/visible": {
            "get": {
                "summary": "Get visible announcements for user",
                "tags": ["Announcements"],
                "security": [{ "bearerAuth": [] }],
                "responses": {
                    "200": { "description": "OK" }
                }
            }
        },

        "/api/announcements/unseen": {
            "get": {
                "summary": "Get unseen announcements",
                "tags": ["Announcements"],
                "security": [{ "bearerAuth": [] }],
                "responses": {
                    "200": { "description": "OK" }
                }
            }
        },

        "/api/announcements/mark-seen": {
            "post": {
                "summary": "Mark announcements as seen",
                "tags": ["Announcements"],
                "security": [{ "bearerAuth": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "announcement_ids": {
                                        "type": "array",
                                        "items": { "type": "integer" }
                                    }
                                },
                                "required": ["announcement_ids"]
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Marked as seen" }
                }
            }
        },

        "/api/notifications": {
            "get": {
                "summary": "Get user notifications",
                "tags": ["Notifications"],
                "security": [{ "bearerAuth": [] }],
                "responses": {
                    "200": { "description": "OK" }
                }
            }
        },

        "/api/notifications/unread": {
            "get": {
                "summary": "Get unread notifications",
                "tags": ["Notifications"],
                "security": [{ "bearerAuth": [] }],
                "responses": {
                    "200": { "description": "OK" }
                }
            }
        },

        "/api/notifications/{id}/read": {
            "post": {
                "summary": "Mark notification as read",
                "tags": ["Notifications"],
                "security": [{ "bearerAuth": [] }],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "integer" }
                    }
                ],
                "responses": {
                    "200": { "description": "Marked as read" }
                }
            }
        }
    },

    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer"
            }
        },

        "schemas": {
            "AnnouncementCreate": {
                "type": "object",
                "properties": {
                    "type": { "type": "string" },
                    "title": { "type": "string" },
                    "body": { "type": "string" },
                    "version": { "type": "string" },
                    "is_active": { "type": "boolean" },
                    "is_pinned": { "type": "boolean" },
                    "starts_at": { "type": "string", "format": "date-time" },
                    "ends_at": { "type": "string", "format": "date-time" }
                },
                "required": ["title", "body"]
            },

            "AnnouncementUpdate": {
                "type": "object",
                "properties": {
                    "type": { "type": "string" },
                    "title": { "type": "string" },
                    "body": { "type": "string" },
                    "version": { "type": "string" },
                    "is_active": { "type": "boolean" },
                    "is_pinned": { "type": "boolean" },
                    "starts_at": { "type": "string", "format": "date-time" },
                    "ends_at": { "type": "string", "format": "date-time" }
                }
            }
        }
    }
}
